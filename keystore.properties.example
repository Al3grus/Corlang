# Copy this file to `keystore.properties` (which is gitignored) and fill in real values.
# The release build reads it to sign the APK/AAB. NEVER commit the real file or the .jks —
# this repo is public, and anyone with your keystore + passwords could sign apps as you.
#
# Generate the keystore once (keep the .jks and these passwords backed up somewhere safe —
# if you lose them you can never update the app under the same signature on the Play Store):
#
#   "$JAVA_HOME/bin/keytool" -genkeypair -v \
#     -keystore corlang-release.jks -alias corlang \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -storepass CHANGE_ME -keypass CHANGE_ME \
#     -dname "CN=Corlang, O=Corlang, C=PT"
#
# storeFile is resolved relative to the repository root.

storeFile=corlang-release.jks
storePassword=CHANGE_ME
keyAlias=corlang
keyPassword=CHANGE_ME
