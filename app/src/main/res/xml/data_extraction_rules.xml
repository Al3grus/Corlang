<?xml version="1.0" encoding="utf-8"?>
<!-- Backup rules for Android 12+ (cloud backup and device-to-device transfer). -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="corlang.db" />
        <include domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="corlang.db" />
        <include domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
