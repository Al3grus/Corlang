<?xml version="1.0" encoding="utf-8"?>
<!-- Corlang logo foreground: Cor(e) + Lang(uage) — a speech bubble (language) holding a
     core: a solid dot wrapped in an open ring that doubles as the letter "C".
     Language-neutral by design (per-language identity lives in the UI, not the brand).
     Geometry sits inside the Ø66dp safe zone of the 108dp adaptive-icon canvas. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Speech bubble body with a bottom-left tail -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M39,33 h30 a9,9 0 0 1 9,9 v21 a9,9 0 0 1 -9,9 H50 L36,80 V72 h3 a9,9 0 0 1 -9,-9 V42 a9,9 0 0 1 9,-9 z" />

    <!-- The "C" ring: Adriatic blue, open to the right (letter C = Corlang) -->
    <path
        android:strokeColor="#135E8C"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M61.5,62.7 A13,13 0 1 1 61.5,41.3" />

    <!-- The core: the essential 20% at the center of the language -->
    <path
        android:fillColor="#C8102E"
        android:pathData="M54,52 m-6,0 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0 z" />
</vector>
