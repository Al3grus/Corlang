<?xml version="1.0" encoding="utf-8"?>
<!-- Corlang launcher foreground: the "Orbit Core" mark (design_handoff_corlang_loader/
     logo-orbit-core.svg) - two broken rings orbiting a molten-red core, the app's identity.
     VectorDrawable has no stroke-dasharray, so each broken ring is a full circle clipped with
     trimPathEnd (outer 132/2pi.33 = 0.6366, inner 80/2pi.21 = 0.6063) inside a rotated group,
     which reproduces the dash + rotation exactly. Scaled to 0.9 and centered at (54,54) so the
     whole mark sits inside the O66 safe zone of the 108 adaptive-icon canvas. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer broken ring (r=33 -> 29.7), rotated -52 like the source -->
    <group
        android:name="outerRing"
        android:pivotX="54"
        android:pivotY="54"
        android:rotation="-52">
        <path
            android:fillColor="#00000000"
            android:pathData="M83.7,54 A29.7,29.7 0 1 1 24.3,54 A29.7,29.7 0 1 1 83.7,54"
            android:strokeColor="#2F7FAE"
            android:strokeLineCap="round"
            android:strokeWidth="5.4"
            android:trimPathEnd="0.6366"
            android:trimPathStart="0" />
    </group>

    <!-- Inner broken ring (r=21 -> 18.9), rotated 128 like the source -->
    <group
        android:name="innerRing"
        android:pivotX="54"
        android:pivotY="54"
        android:rotation="128">
        <path
            android:fillColor="#00000000"
            android:pathData="M72.9,54 A18.9,18.9 0 1 1 35.1,54 A18.9,18.9 0 1 1 72.9,54"
            android:strokeColor="#2F7FAE"
            android:strokeLineCap="round"
            android:strokeWidth="5.4"
            android:trimPathEnd="0.6063"
            android:trimPathStart="0" />
    </group>

    <!-- Molten core (r=9 -> 8.1) -->
    <path
        android:fillColor="#C8402C"
        android:pathData="M54,54 m-8.1,0 a8.1,8.1 0 1,0 16.2,0 a8.1,8.1 0 1,0 -16.2,0 z" />
</vector>
